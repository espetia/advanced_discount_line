<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View: Tree -->
    <record id="view_increment_line_configuration_tree" model="ir.ui.view">
        <field name="name">increment.line.configuration.tree</field>
        <field name="model">increment.line.configuration</field>
        <field name="arch" type="xml">
            <tree string="Increment Configurations">
                <field name="name" />
                <field name="increment" />
                <field name="valid_from" />
                <field name="valid_to" />
                <field name="min_amount" />
            </tree>
        </field>
    </record>

    <!-- View: Form -->
    <record id="view_increment_line_configuration_form" model="ir.ui.view">
        <field name="name">increment.line.configuration.form</field>
        <field name="model">increment.line.configuration</field>
        <field name="arch" type="xml">
            <form string="Increment Configuration">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" placeholder="E.g. Holiday Increase (10%)" />
                        </h1>
                    </div>
                    <group>
                        <group name="general">
                            <field name="increment" />
                            <field name="min_amount" />
                        </group>
                        <group name="dates">
                            <field name="valid_from" />
                            <field name="valid_to" />
                        </group>
                    </group>
                    <notebook>
                        <page name="products" string="Permitted Products">
                            <field name="permited_products">
                                <tree>
                                    <field name="default_code" optional="show" />
                                    <field name="name" />
                                </tree>
                            </field>
                        </page>
                        <page name="users" string="Permitted Users">
                            <field name="permited_users">
                                <tree>
                                    <field name="name" />
                                    <field name="login" optional="show" />
                                </tree>
                            </field>
                        </page>
                        <page name="customers" string="Permitted Customers">
                            <field name="permited_customers">
                                <tree>
                                    <field name="name" />
                                    <field name="email" optional="show" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_increment_line_configuration" model="ir.actions.act_window">
        <field name="name">Increment Rules (Advanced)</field>
        <field name="res_model">increment.line.configuration</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Implement your first increment configuration.
            </p>
        </field>
    </record>

    <!-- Menu Item (Inherited from sale config) -->
    <menuitem id="menu_increment_line_config"
        name="Increment Rules"
        parent="sale.menu_sale_config"
        groups="advanced_discount_line.group_advanced_discount_manager"
        action="action_increment_line_configuration"
        sequence="56" />
</odoo>