<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View: Tree -->
    <record id="view_discount_line_configuration_tree" model="ir.ui.view">
        <field name="name">discount.line.configuration.tree</field>
        <field name="model">discount.line.configuration</field>
        <field name="arch" type="xml">
            <tree string="Discount Configurations">
                <field name="name" />
                <field name="discount" />
                <field name="valid_from" />
                <field name="valid_to" />
                <field name="min_amount" />
            </tree>
        </field>
    </record>

    <!-- View: Form -->
    <record id="view_discount_line_configuration_form" model="ir.ui.view">
        <field name="name">discount.line.configuration.form</field>
        <field name="model">discount.line.configuration</field>
        <field name="arch" type="xml">
            <form string="Discount Configuration">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" placeholder="E.g. Holiday Promotion (10%)" />
                        </h1>
                    </div>
                    <group>
                        <group name="general">
                            <field name="discount" />
                            <field name="min_amount" />
                        </group>
                        <group name="dates">
                            <field name="valid_from" />
                            <field name="valid_to" />
                        </group>
                    </group>
                    <notebook>
                        <page name="products" string="Permitted Products">
                            <field name="permited_products">
                                <tree>
                                    <field name="default_code" optional="show" />
                                    <field name="name" />
                                </tree>
                            </field>
                        </page>
                        <page name="users" string="Permitted Users">
                            <field name="permited_users">
                                <tree>
                                    <field name="name" />
                                    <field name="login" optional="show" />
                                </tree>
                            </field>
                        </page>
                        <page name="customers" string="Permitted Customers">
                            <field name="permited_customers">
                                <tree>
                                    <field name="name" />
                                    <field name="email" optional="show" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_discount_line_configuration" model="ir.actions.act_window">
        <field name="name">Discount Rules (Advanced)</field>
        <field name="res_model">discount.line.configuration</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Implement your first discount configuration.
            </p>
        </field>
    </record>

    <!-- Menu Item (Inherited from sale config) -->
    <menuitem id="menu_discount_line_config"
        name="Discount Rules"
        parent="sale.menu_sale_config"
        groups="advanced_discount_line.group_advanced_discount_manager"
        action="action_discount_line_configuration"
        sequence="55" />
</odoo>